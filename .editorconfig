# EditorConfig para w11-nasa-theme
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{py,pyi}]
indent_style = space
indent_size = 4

[*.{ps1,psm1,psd1}]
indent_style = space
indent_size = 4

[*.{md,json,yaml,yml,toml}]
indent_style = space
indent_size = 2

[*.{theme,ini}]
indent_style = space
indent_size = 4
